---
const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://app.grassion.com'
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pricing · Grassion</title>
  <meta name="description" content="Simple per-developer pricing. 14-day free trial. No credit card required." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,200;0,9..40,300;0,9..40,400;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #000000;
      --white: #ffffff;
      --dim: rgba(255,255,255,0.38);
      --dimmer: rgba(255,255,255,0.18);
      --line: rgba(255,255,255,0.09);
    }

    html, body {
      background: var(--black);
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
    }

    /* ── HEADER ─────────────────────────────── */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 18px 52px;
      z-index: 100;
      border-bottom: 1px solid var(--line);
      background: rgba(0,0,0,0.85);
      backdrop-filter: blur(16px);
    }

    nav { display: flex; gap: 40px; align-items: center; }
    nav a {
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
      text-decoration: none;
      transition: color 0.2s;
    }
    nav a:hover, nav a.active { color: var(--white); }

    .logo-link {
      position: fixed;
      top: 20px; left: 24px;
      z-index: 1000;
    }
    .logo-link img { height: 36px; display: block; }

    /* ── MAIN ───────────────────────────────── */
    main {
      padding: 120px 52px 80px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 36px; height: 1px;
      background: rgba(255,255,255,0.28);
    }

    h1 {
      font-size: clamp(36px, 4vw, 56px);
      font-weight: 200;
      line-height: 1.1;
      letter-spacing: -0.025em;
      margin-bottom: 16px;
    }

    .hero-sub {
      font-size: 14px;
      font-weight: 300;
      color: var(--dim);
      margin-bottom: 60px;
      line-height: 1.7;
    }

    /* ── PLAN GRID ──────────────────────────── */
    .plans-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
      margin-bottom: 80px;
    }

    .plan-card {
      background: var(--black);
      padding: 40px 28px;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .plan-card.featured {
      background: rgba(255,255,255,0.03);
    }

    .plan-popular {
      position: absolute;
      top: -1px; left: 50%;
      transform: translateX(-50%);
      font-family: 'DM Mono', monospace;
      font-size: 8px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      background: var(--white);
      color: var(--black);
      padding: 4px 12px;
      white-space: nowrap;
    }

    .plan-name {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 20px;
    }

    .plan-price {
      font-size: 32px;
      font-weight: 200;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
      line-height: 1;
    }

    .plan-price-usd {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: rgba(255,255,255,0.3);
      margin-bottom: 8px;
    }

    .plan-unit {
      font-size: 12px;
      font-weight: 300;
      color: rgba(255,255,255,0.35);
      margin-bottom: 4px;
    }

    .plan-best {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.22);
      margin-bottom: 28px;
      text-transform: uppercase;
    }

    .plan-divider {
      height: 1px;
      background: var(--line);
      margin-bottom: 24px;
    }

    .plan-features {
      list-style: none;
      flex: 1;
      margin-bottom: 32px;
    }

    .plan-features li {
      font-size: 13px;
      font-weight: 300;
      color: var(--dim);
      padding: 7px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      display: flex;
      align-items: flex-start;
      gap: 10px;
      line-height: 1.4;
    }

    .plan-features li::before {
      content: '·';
      color: rgba(255,255,255,0.3);
      flex-shrink: 0;
      margin-top: 1px;
    }

    .plan-features li.inherit {
      color: rgba(255,255,255,0.22);
      font-size: 12px;
    }
    .plan-features li.inherit::before { content: '↳'; font-size: 10px; }

    .plan-cta {
      display: block;
      width: 100%;
      text-align: center;
      padding: 13px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid rgba(255,255,255,0.2);
      color: var(--white);
      transition: background 0.2s, border-color 0.2s;
    }

    .plan-cta:hover {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.4);
    }

    .plan-card.featured .plan-cta {
      background: var(--white);
      color: var(--black);
      border-color: var(--white);
    }
    .plan-card.featured .plan-cta:hover { opacity: 0.87; }

    .plan-hint {
      text-align: center;
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: rgba(255,255,255,0.2);
      letter-spacing: 0.1em;
      margin-top: 10px;
    }

    /* ── RAZORPAY NOTE ──────────────────────── */
    .payment-note {
      display: flex;
      align-items: center;
      gap: 16px;
      border: 1px solid var(--line);
      padding: 18px 24px;
      margin-bottom: 60px;
      background: rgba(255,255,255,0.02);
    }

    .payment-note-icon {
      width: 36px; height: 36px;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: rgba(255,255,255,0.3);
      letter-spacing: 0.06em;
    }

    .payment-note-text {
      font-size: 13px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.6;
    }

    .payment-note-text strong {
      color: var(--white);
      font-weight: 400;
    }

    /* ── FAQ ────────────────────────────────── */
    .faq-section { margin-bottom: 60px; }

    .faq-label {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 28px;
    }

    details {
      border-bottom: 1px solid var(--line);
    }

    summary {
      cursor: pointer;
      padding: 20px 0;
      font-size: 15px;
      font-weight: 300;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: var(--white);
      user-select: none;
    }

    summary::-webkit-details-marker { display: none; }

    summary::after {
      content: '+';
      font-family: 'DM Mono', monospace;
      font-size: 18px;
      font-weight: 300;
      color: rgba(255,255,255,0.3);
      transition: transform 0.2s;
    }

    details[open] summary::after {
      transform: rotate(45deg);
    }

    details p {
      font-size: 14px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.7;
      padding-bottom: 20px;
    }

    details a { color: var(--white); text-decoration: underline; text-underline-offset: 3px; }

    /* ── FOOTER ─────────────────────────────── */
    footer {
      border-top: 1px solid var(--line);
      padding: 20px 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    footer span {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--dimmer);
      letter-spacing: 0.08em;
    }

    footer a {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--dimmer);
      letter-spacing: 0.08em;
      text-decoration: none;
      transition: color 0.2s;
    }
    footer a:hover { color: var(--white); }

    /* ── FLOATING ELEMENT ───────────────────── */
    .float-badge {
      position: fixed;
      bottom: 80px;
      right: 28px;
      background: rgba(10,10,10,0.95);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      padding: 12px 16px;
      font-family: 'DM Mono', monospace;
      backdrop-filter: blur(12px);
      z-index: 50;
      animation: floatBadge 4s ease-in-out infinite;
    }
    @keyframes floatBadge {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    .float-badge-label {
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 4px;
    }
    .float-badge-value {
      font-size: 12px;
      font-weight: 500;
      color: var(--white);
    }

    /* ── MOBILE ─────────────────────────────── */
    @media (max-width: 1023px) {
      .plans-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 767px) {
      .logo-link { top: 14px; left: 16px; }
      .logo-link img { height: 28px; }
      header { padding: 14px 16px; }
      nav { gap: 16px; }

      main { padding: 88px 24px 60px; }

      h1 { font-size: clamp(28px, 9vw, 40px); }

      .plans-grid { grid-template-columns: 1fr; }

      .payment-note { flex-direction: column; align-items: flex-start; }

      footer { padding: 16px 24px; flex-direction: column; gap: 8px; text-align: center; }

      .float-badge { display: none; }
    }
  </style>
</head>
<body>

  <a href="/" class="logo-link">
    <img src="/grassion-logo-white.svg" alt="Grassion" onerror="this.style.display='none'" />
  </a>

  <header>
    <nav>
      <a href="/">Home</a>
      <a href="/about/">About</a>
      <a href="/pricing/" class="active">Pricing</a>
      <a href="/contact/">Contact</a>
    </nav>
  </header>

  <main>
    <div class="eyebrow">Pricing</div>
    <h1>Simple, honest pricing.</h1>
    <p class="hero-sub">
      Charged per active developer. 14-day free trial. No credit card to start. Cancel anytime.
      Features unlock instantly after payment · managed in your dashboard.
    </p>

    <!-- PLAN CARDS -->
    <div class="plans-grid">

      <!-- Starter -->
      <div class="plan-card">
        <div class="plan-name">Starter</div>
        <div class="plan-price">$19</div>
        <div class="plan-price-usd">&nbsp;</div>
        <div class="plan-unit">per developer / month</div>
        <div class="plan-best">Best for 1–10 devs</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li>All repos monitored — no limit</li>
          <li>AI PR detection via label, git trailer &amp; body pattern</li>
          <li>Weekly ROI verdict — Net Positive / Neutral / Negative</li>
          <li>Problem PR alerts with AI-generated summaries</li>
          <li>Seat waste analysis — spot unused AI seats</li>
          <li>Weekly email digest</li>
          <li>GitHub App · 5-minute setup</li>
          <li>Email support</li>
        </ul>
        <a class="plan-cta" href={`${APP_URL}/login`}>Start Free Trial</a>
        <p class="plan-hint">14-day trial · no card required</p>
      </div>

      <!-- Team (featured) -->
      <div class="plan-card featured">
        <div class="plan-popular">Most Popular</div>
        <div class="plan-name">Team</div>
        <div class="plan-price">$15</div>
        <div class="plan-price-usd">&nbsp;</div>
        <div class="plan-unit">per developer / month</div>
        <div class="plan-best">Min 10 seats · Best for 10–30 devs</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li class="inherit">Everything in Starter</li>
          <li>Per-developer ROI breakdown in dashboard</li>
          <li>Developer-level seat waste table</li>
          <li>AI adoption rate by team member</li>
          <li>Priority email support</li>
          <li>API access (coming Q3 2026)</li>
        </ul>
        <a class="plan-cta" href={`${APP_URL}/login`}>Start Free Trial</a>
        <p class="plan-hint">14-day trial · no card required</p>
      </div>

      <!-- Business -->
      <div class="plan-card">
        <div class="plan-name">Business</div>
        <div class="plan-price">$499</div>
        <div class="plan-price-usd">&nbsp;</div>
        <div class="plan-unit">flat / month · unlimited devs</div>
        <div class="plan-best">Best for 30–50 devs</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li class="inherit">Everything in Team</li>
          <li>Executive ROI report card in dashboard</li>
          <li>Annual ROI projection &amp; efficiency score</li>
          <li>Dedicated onboarding session</li>
          <li>24h support SLA</li>
          <li>Slack notifications (coming Q3 2026)</li>
        </ul>
        <a class="plan-cta" href={`${APP_URL}/login`}>Start Free Trial</a>
        <p class="plan-hint">14-day trial · no card required</p>
      </div>

      <!-- Enterprise -->
      <div class="plan-card">
        <div class="plan-name">Enterprise</div>
        <div class="plan-price" style="font-size: 20px; padding-top: 8px;">Contact us</div>
        <div class="plan-price-usd">&nbsp;</div>
        <div class="plan-unit">tailored to your usage</div>
        <div class="plan-best">50+ devs</div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li class="inherit">Everything in Business</li>
          <li>Custom contract &amp; SLA</li>
          <li>SSO / SAML (roadmap)</li>
          <li>On-premise deployment option</li>
          <li>Dedicated account manager</li>
          <li>Custom data retention policy</li>
          <li>Team benchmarking (coming Q3 2026)</li>
        </ul>
        <a class="plan-cta" href="/contact/">Contact Sales</a>
        <p class="plan-hint">We respond within 24 hours</p>
      </div>

    </div>

    <!-- PAYMENT NOTE -->
    <div class="payment-note">
      <div class="payment-note-icon">PAY</div>
      <p class="payment-note-text">
        <strong>All prices in USD.</strong> Charged via Razorpay — supports credit/debit cards and UPI.
        Clicking "Start Free Trial" takes you to the dashboard. Choose your plan there to go directly to checkout.
        Features activate instantly after payment.
      </p>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
      <div class="faq-label">Billing FAQ</div>

      <details>
        <summary>Do you charge per repo or per developer?</summary>
        <p>Per active developer. Repos are unlimited across all plans.</p>
      </details>

      <details>
        <summary>Which payment methods are supported?</summary>
        <p>UPI, debit/credit cards (domestic and international), and netbanking via Razorpay. Annual invoicing available on Business and Enterprise plans.</p>
      </details>

      <details>
        <summary>What happens after the free trial?</summary>
        <p>You'll be prompted to add a payment method. No charge is made until you confirm. If you don't subscribe, data is retained for 30 days.</p>
      </details>

      <details>
        <summary>Do you offer refunds?</summary>
        <p>Pro-rated refunds for annual plans. Monthly plans are evaluated case-by-case — write to <a href="mailto:info@grassion.com">info@grassion.com</a>.</p>
      </details>

      <details>
        <summary>Can I upgrade or downgrade anytime?</summary>
        <p>Yes. Plan changes take effect at the next billing cycle. Upgrades can be applied immediately on request.</p>
      </details>
    </div>

  </main>

  <footer>
    <span>© 2026 Grassion Intelligence</span>
    <div style="display:flex; gap:24px;">
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="mailto:info@grassion.com">info@grassion.com</a>
    </div>
  </footer>

  <!-- Floating element -->
  <div class="float-badge">
    <div class="float-badge-label">Free Trial</div>
    <div class="float-badge-value">14 days · no card</div>
  </div>

</body>
</html>
