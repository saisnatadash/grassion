---
import Base from '../layouts/Base.astro'
---

<Base title="Page not found" description="Page not found">
  <section class="py-16 text-center">
    <h1 class="text-4xl font-semibold tracking-tight">404</h1>
    <p class="mt-2 text-neutral-700">That page doesn't exist.</p>
    <a
      href="/"
      class="mt-6 inline-block rounded-md bg-ink px-4 py-2 text-sm font-medium text-white hover:bg-neutral-800"
    >
      Back home
    </a>
  </section>
</Base>
