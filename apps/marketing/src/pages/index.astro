---
// Grassion Marketing Landing Page
// File: apps/marketing/src/pages/index.astro
// Drop this file directly into your pages folder — no other changes needed
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grassion — Where AI Code Meets Accountability</title>
  <meta name="description" content="The first system that tells engineering teams whether AI is creating value or silently creating rework." />
  <meta property="og:title" content="Grassion — AI Code Accountability Layer" />
  <meta property="og:description" content="Find out which Copilot/Cursor seats your team isn't using and whether AI is actually improving your codebase." />
  <meta property="og:url" content="https://grassion.com" />
  <meta name="twitter:card" content="summary_large_image" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,wght@0,200;0,300;0,400;1,300&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #000000;
      --white: #ffffff;
      --dim: rgba(255,255,255,0.35);
      --line: rgba(255,255,255,0.1);
    }

    html, body {
      height: 100%;
      overflow: hidden;
      background: var(--black);
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
    }

    /* —— HEADER —— */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 28px 48px;
      z-index: 100;
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(12px);
    }

    .logo {
      font-family: 'DM Mono', monospace;
      font-weight: 500;
      font-size: 15px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--white);
      text-decoration: none;
    }

    .logo span {
      display: inline-block;
      width: 7px; height: 7px;
      background: white;
      border-radius: 50%;
      margin-right: 8px;
      vertical-align: middle;
      animation: pulse 2.4s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }

    nav { display: flex; gap: 36px; }

    nav a {
      font-size: 12px;
      font-weight: 300;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--dim);
      text-decoration: none;
      transition: color 0.2s;
    }

    nav a:hover { color: var(--white); }

    /* —— MAIN LAYOUT —— */
    main {
      height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 0 48px;
    }

    /* —— LEFT COPY —— */
    .copy { padding-right: 60px; }

    .eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .eyebrow::before {
      content: '';
      display: block;
      width: 32px;
      height: 1px;
      background: var(--dim);
    }

    h1 {
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(30px, 3.2vw, 48px);
      font-weight: 200;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 24px;
    }

    h1 em { font-style: italic; font-weight: 300; }

    .sub {
      font-size: 14px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.7;
      max-width: 380px;
      margin-bottom: 40px;
    }

    .flow {
      display: flex;
      gap: 8px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .flow-tag {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      border: 1px solid rgba(255,255,255,0.12);
      padding: 5px 10px;
      border-radius: 2px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .flow-tag::after {
      content: '→';
      color: rgba(255,255,255,0.2);
      font-size: 9px;
    }

    .flow-tag:last-child::after { display: none; }

    .cta-wrap {
      display: flex;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 3px;
      overflow: hidden;
      max-width: 400px;
      transition: border-color 0.2s;
    }

    .cta-wrap:focus-within { border-color: rgba(255,255,255,0.6); }

    .cta-wrap input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--white);
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      font-weight: 300;
      letter-spacing: 0.05em;
      padding: 14px 18px;
    }

    .cta-wrap input::placeholder { color: var(--dim); }

    .cta-wrap button {
      background: var(--white);
      color: var(--black);
      border: none;
      cursor: pointer;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 14px 22px;
      transition: opacity 0.2s;
      white-space: nowrap;
    }

    .cta-wrap button:hover { opacity: 0.85; }

    .hint {
      margin-top: 14px;
      font-size: 11px;
      color: rgba(255,255,255,0.22);
      font-family: 'DM Mono', monospace;
      letter-spacing: 0.05em;
    }

    /* —— RIGHT: 3D SCENE —— */
    .scene {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      position: relative;
    }

    .orbit {
      width: 320px;
      height: 320px;
      position: relative;
      perspective: 900px;
    }

    .ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.12);
      animation: spinRing 18s linear infinite;
      transform-style: preserve-3d;
    }

    .ring::after {
      content: '';
      position: absolute;
      top: 50%; left: -4px;
      width: 8px; height: 8px;
      background: white;
      border-radius: 50%;
      transform: translateY(-50%);
      box-shadow: 0 0 12px 3px rgba(255,255,255,0.4);
    }

    .ring-2 {
      inset: 40px;
      border-color: rgba(255,255,255,0.08);
      animation: spinRing 11s linear infinite reverse;
    }

    .ring-2::after {
      background: rgba(255,255,255,0.6);
      width: 5px; height: 5px;
      left: -2.5px;
      box-shadow: 0 0 8px 2px rgba(255,255,255,0.3);
    }

    @keyframes spinRing {
      from { transform: rotateX(68deg) rotateZ(0deg); }
      to   { transform: rotateX(68deg) rotateZ(360deg); }
    }

    .cube-wrap {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cube {
      width: 80px; height: 80px;
      position: relative;
      transform-style: preserve-3d;
      animation: rotateCube 9s ease-in-out infinite;
    }

    @keyframes rotateCube {
      0%   { transform: rotateX(15deg) rotateY(0deg); }
      25%  { transform: rotateX(15deg) rotateY(90deg); }
      50%  { transform: rotateX(15deg) rotateY(180deg); }
      75%  { transform: rotateX(15deg) rotateY(270deg); }
      100% { transform: rotateX(15deg) rotateY(360deg); }
    }

    .face {
      position: absolute;
      width: 80px; height: 80px;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.02);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      font-weight: 400;
      letter-spacing: 0.15em;
      color: rgba(255,255,255,0.25);
    }

    .face-front  { transform: translateZ(40px); }
    .face-back   { transform: rotateY(180deg) translateZ(40px); }
    .face-left   { transform: rotateY(-90deg) translateZ(40px); }
    .face-right  { transform: rotateY(90deg) translateZ(40px); }
    .face-top    { transform: rotateX(90deg) translateZ(40px); }
    .face-bottom { transform: rotateX(-90deg) translateZ(40px); }

    .glow {
      position: absolute;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .stats {
      position: absolute;
      bottom: 60px;
      left: 0; right: 0;
      display: flex;
      justify-content: center;
    }

    .stat {
      padding: 12px 20px;
      border: 1px solid var(--line);
      border-right: none;
      text-align: center;
    }

    .stat:last-child { border-right: 1px solid var(--line); }

    .stat-num {
      font-family: 'DM Mono', monospace;
      font-size: 18px;
      font-weight: 400;
      color: white;
      display: block;
      margin-bottom: 3px;
    }

    .stat-label {
      font-size: 9px;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
    }

    /* —— ASK WIDGET —— */
    .ask-btn {
      position: fixed;
      bottom: 28px; right: 28px;
      width: 44px; height: 44px;
      background: var(--white);
      color: var(--black);
      border: none;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 200;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .ask-btn:hover {
      transform: scale(1.08);
      box-shadow: 0 0 0 8px rgba(255,255,255,0.06);
    }

    .ask-btn svg { width: 18px; height: 18px; }

    .ask-panel {
      position: fixed;
      bottom: 84px; right: 28px;
      width: 300px;
      background: #0a0a0a;
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 8px;
      overflow: hidden;
      z-index: 200;
      transform: scale(0.92) translateY(12px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1), opacity 0.18s ease;
      transform-origin: bottom right;
    }

    .ask-panel.open {
      transform: scale(1) translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    .ask-header {
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .ask-dot {
      width: 7px; height: 7px;
      background: white;
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }

    .ask-title {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.1em;
      color: var(--white);
    }

    .ask-body { padding: 14px 16px; }

    .ask-body p {
      font-size: 12px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.6;
      margin-bottom: 14px;
    }

    .ask-form {
      display: flex;
      border: 1px solid var(--line);
      border-radius: 3px;
      overflow: hidden;
    }

    .ask-form input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--white);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      padding: 10px 12px;
    }

    .ask-form input::placeholder { color: rgba(255,255,255,0.2); }

    .ask-form button {
      background: var(--white);
      color: var(--black);
      border: none;
      cursor: pointer;
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.1em;
      padding: 10px 14px;
      transition: opacity 0.2s;
    }

    .ask-form button:hover { opacity: 0.8; }

    footer {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      padding: 16px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid var(--line);
    }

    footer span {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: rgba(255,255,255,0.18);
      letter-spacing: 0.08em;
    }

    .success-msg {
      display: none;
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--dim);
      letter-spacing: 0.08em;
      padding: 14px 0;
    }
  </style>
</head>
<body>

  <header>
    <a class="logo" href="/"><span></span>Grassion</a>
    <nav>
      <a href="#about">About</a>
      <a href="mailto:info@grassion.com">Contact</a>
    </nav>
  </header>

  <main>
    <div class="copy">
      <div class="eyebrow">AI Coding ROI Intelligence</div>
      <h1>Where AI Code<br>Meets<br><em>Accountability.</em></h1>
      <p class="sub">
        The first system that tells engineering teams whether AI is creating value — or silently creating rework.
      </p>
      <div class="flow">
        <span class="flow-tag">Connect</span>
        <span class="flow-tag">Detect</span>
        <span class="flow-tag">Measure</span>
        <span class="flow-tag">Decide</span>
      </div>
      <div class="cta-wrap" id="ctaWrap">
        <input type="email" id="emailInput" placeholder="your@company.com" autocomplete="off" />
        <button id="joinBtn">Join the Standard</button>
      </div>
      <p class="hint" id="hintText">14-day free trial &nbsp;·&nbsp; 5-minute GitHub setup</p>
      <div class="success-msg" id="successMsg">✓ &nbsp;You're on the list. We'll be in touch.</div>
    </div>

    <div class="scene">
      <div class="orbit">
        <div class="ring"></div>
        <div class="ring ring-2"></div>
        <div class="cube-wrap">
          <div class="glow"></div>
          <div class="cube">
            <div class="face face-front">ROI</div>
            <div class="face face-back">DETECT</div>
            <div class="face face-left">TRACK</div>
            <div class="face face-right">SIGNAL</div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
          </div>
        </div>
      </div>
      <div class="stats">
        <div class="stat">
          <span class="stat-num">85%</span>
          <span class="stat-label">devs use AI tools</span>
        </div>
        <div class="stat">
          <span class="stat-num">0%</span>
          <span class="stat-label">have ROI visibility</span>
        </div>
        <div class="stat">
          <span class="stat-num">5 min</span>
          <span class="stat-label">to first insight</span>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <span>© 2026 Grassion Intelligence</span>
    <span>Where AI Code Meets Accountability</span>
  </footer>

  <button class="ask-btn" id="askToggle" title="Ask us anything">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="ask-panel" id="askPanel">
    <div class="ask-header">
      <div class="ask-dot"></div>
      <span class="ask-title">Ask us anything</span>
    </div>
    <div class="ask-body">
      <p>Question about Grassion or want early access? We reply personally.</p>
      <div class="ask-form">
        <input type="text" id="askInput" placeholder="Type your question..." />
        <button id="askSend">Send</button>
      </div>
    </div>
  </div>

  <script is:inline>
    // —— Ask widget ————————————————————————————————————————
    const askPanel  = document.getElementById('askPanel');
    const askToggle = document.getElementById('askToggle');
    const askInput  = document.getElementById('askInput');
    const askSend   = document.getElementById('askSend');

    askToggle.addEventListener('click', () => askPanel.classList.toggle('open'));

    document.addEventListener('click', e => {
      if (!askPanel.contains(e.target) && !askToggle.contains(e.target)) {
        askPanel.classList.remove('open');
      }
    });

    function sendAsk() {
      const q = askInput.value.trim();
      if (!q) return;
      window.location.href =
        `mailto:info@grassion.com?subject=Question via grassion.com&body=${encodeURIComponent(q)}`;
      askInput.value = '';
    }

    askSend.addEventListener('click', sendAsk);
    askInput.addEventListener('keydown', e => { if (e.key === 'Enter') sendAsk(); });

    // —— Waitlist join ————————————————————————————————————
    // ⚠️  REPLACE the value below with your real Tally form ID
    //     Go to tally.so → create form → copy the ID from the URL
    const WAITLIST_URL = 'https://tally.so/r/YOUR_FORM_ID';

    const joinBtn    = document.getElementById('joinBtn');
    const emailInput = document.getElementById('emailInput');
    const ctaWrap    = document.getElementById('ctaWrap');
    const hintText   = document.getElementById('hintText');
    const successMsg = document.getElementById('successMsg');

    function handleJoin() {
      const email = emailInput.value.trim();
      if (!email || !email.includes('@')) { emailInput.focus(); return; }
      window.open(`${WAITLIST_URL}?email=${encodeURIComponent(email)}`, '_blank');
      ctaWrap.style.display    = 'none';
      hintText.style.display   = 'none';
      successMsg.style.display = 'block';
    }

    joinBtn.addEventListener('click', handleJoin);
    emailInput.addEventListener('keydown', e => { if (e.key === 'Enter') handleJoin(); });

    // —— Stat entrance animation ——————————————————————————
    window.addEventListener('load', () => {
      document.querySelectorAll('.stat').forEach((s, i) => {
        s.style.cssText = 'opacity:0;transform:translateY(8px);transition:opacity .5s ease,transform .5s ease';
        setTimeout(() => { s.style.opacity='1'; s.style.transform='translateY(0)'; }, 600 + i*120);
      });
    });
  </script>

</body>
</html>
