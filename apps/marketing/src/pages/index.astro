---
// apps/marketing/src/pages/index.astro
import Layout from '../layouts/Layout.astro';

const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.grassion.com';
---

<Layout title="Grassion - AI-Powered GitHub Issue Management">
  <main class="min-h-screen bg-gradient-to-br from-teal-50 via-white to-emerald-50">
    
    <!-- Navigation -->
    <nav class="container mx-auto px-6 py-6 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-br from-teal-600 to-emerald-600 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <span class="text-2xl font-bold bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">
          Grassion
        </span>
      </div>
      <a 
        href={`${appUrl}/install`}
        class="px-6 py-2.5 bg-gradient-to-r from-teal-600 to-emerald-600 text-white rounded-lg font-medium hover:shadow-lg transition-all"
      >
        Sign In
      </a>
    </nav>

    <!-- Hero Section -->
    <section class="container mx-auto px-6 pt-20 pb-32 text-center">
      <div class="inline-block mb-6 px-4 py-2 bg-teal-100 text-teal-700 rounded-full text-sm font-semibold">
        🚀 Now in Beta - Free for Early Adopters
      </div>
      
      <h1 class="text-6xl md:text-7xl font-bold mb-6 leading-tight">
        AI That Resolves Your<br/>
        <span class="bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent">
          GitHub Issues
        </span>
      </h1>
      
      <p class="text-xl text-gray-600 mb-12 max-w-2xl mx-auto leading-relaxed">
        Connect your repository, let Grassion analyze issues, and watch as AI generates pull requests with working solutions—automatically.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href={`${appUrl}/install`}
          class="group px-8 py-4 bg-gradient-to-r from-teal-600 to-emerald-600 text-white rounded-xl font-semibold text-lg hover:shadow-2xl transition-all flex items-center gap-2"
        >
          Get Early Access
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        
        <a 
          href="#how-it-works"
          class="px-8 py-4 bg-white border-2 border-gray-300 text-gray-700 rounded-xl font-semibold text-lg hover:border-teal-600 hover:text-teal-600 transition-all"
        >
          See How It Works
        </a>
      </div>

      <p class="mt-8 text-sm text-gray-500">
        No credit card required • 5 free AI resolutions • Install in 30 seconds
      </p>
    </section>

    <!-- Stats Section -->
    <section class="container mx-auto px-6 pb-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-lg text-center">
          <div class="text-5xl font-bold text-teal-600 mb-2">5min</div>
          <div class="text-gray-600">Average Resolution Time</div>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-lg text-center">
          <div class="text-5xl font-bold text-teal-600 mb-2">87%</div>
          <div class="text-gray-600">Success Rate</div>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-lg text-center">
          <div class="text-5xl font-bold text-teal-600 mb-2">24/7</div>
          <div class="text-gray-600">Automated Monitoring</div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="container mx-auto px-6 py-20">
      <h2 class="text-4xl font-bold text-center mb-16">How It Works</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-16 h-16 bg-teal-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl font-bold text-teal-600">1</span>
          </div>
          <h3 class="text-xl font-bold mb-3">Install GitHub App</h3>
          <p class="text-gray-600">Connect Grassion to your repositories in one click. Works with public and private repos.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-emerald-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl font-bold text-emerald-600">2</span>
          </div>
          <h3 class="text-xl font-bold mb-3">AI Analyzes Issues</h3>
          <p class="text-gray-600">Our AI reads your issue, understands context, and analyzes your codebase to find the root cause.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-teal-100 rounded-2xl flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl font-bold text-teal-600">3</span>
          </div>
          <h3 class="text-xl font-bold mb-3">Get Pull Requests</h3>
          <p class="text-gray-600">Receive a PR with the fix, complete with tests and explanation. Review and merge when ready.</p>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="container mx-auto px-6 py-20">
      <h2 class="text-4xl font-bold text-center mb-16">Simple, Transparent Pricing</h2>
      
      <div class="max-w-md mx-auto bg-white rounded-2xl shadow-2xl overflow-hidden border-2 border-teal-600">
        <div class="bg-gradient-to-r from-teal-600 to-emerald-600 text-white p-8 text-center">
          <h3 class="text-2xl font-bold mb-2">Starter Plan</h3>
          <div class="text-5xl font-bold mb-2">₹499<span class="text-2xl font-normal">/mo</span></div>
          <p class="text-teal-100">Perfect for solo developers</p>
        </div>
        
        <div class="p-8">
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-gray-700">25 AI resolutions per month</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-gray-700">Connect unlimited repositories</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-gray-700">Priority support</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-gray-700">Advanced AI models (GPT-4o)</span>
            </li>
          </ul>
          
          <a 
            href={`${appUrl}/install`}
            class="block w-full py-4 bg-gradient-to-r from-teal-600 to-emerald-600 text-white rounded-xl font-semibold text-center hover:shadow-lg transition-all"
          >
            Start Free Trial
          </a>
          
          <p class="text-center text-sm text-gray-500 mt-4">
            5 free resolutions • No credit card required
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="container mx-auto px-6 py-20">
      <div class="bg-gradient-to-r from-teal-600 to-emerald-600 rounded-3xl p-12 text-center text-white">
        <h2 class="text-4xl font-bold mb-4">Ready to Ship Faster?</h2>
        <p class="text-xl mb-8 text-teal-100">Join developers who are resolving issues 10x faster with AI</p>
        <a 
          href={`${appUrl}/install`}
          class="inline-block px-8 py-4 bg-white text-teal-600 rounded-xl font-semibold text-lg hover:shadow-2xl transition-all"
        >
          Get Started Free
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="container mx-auto px-6 py-12 border-t border-gray-200">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-gradient-to-br from-teal-600 to-emerald-600 rounded-lg"></div>
          <span class="text-xl font-bold text-gray-800">Grassion</span>
        </div>
        
        <div class="flex gap-8 text-gray-600">
          <a href="#" class="hover:text-teal-600 transition-colors">Privacy</a>
          <a href="#" class="hover:text-teal-600 transition-colors">Terms</a>
          <a href="mailto:info@grassion.com" class="hover:text-teal-600 transition-colors">Contact</a>
        </div>
      </div>
      
      <div class="text-center mt-8 text-gray-500 text-sm">
        © 2024 Grassion. All rights reserved.
      </div>
    </footer>

  </main>
</Layout>