---
// Grassion Marketing Landing Page
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Grassion — Where AI Code Meets Accountability</title>
  <meta name="description" content="The first system that tells engineering teams whether AI is creating value or silently creating rework." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,200;0,9..40,300;0,9..40,400;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #000000;
      --white: #ffffff;
      --dim: rgba(255,255,255,0.38);
      --dimmer: rgba(255,255,255,0.18);
      --line: rgba(255,255,255,0.09);
    }

    html, body {
      height: 100%;
      overflow: hidden;
      background: var(--black);
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
    }

    /* ── HEADER ─────────────────────────────── */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 18px 52px;
      z-index: 100;
      border-bottom: 1px solid var(--line);
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(16px);
    }

    nav { display: flex; gap: 40px; align-items: center; }

    nav a {
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
      text-decoration: none;
      transition: color 0.2s;
    }

    nav a:hover { color: var(--white); }

    /* ── MAIN ───────────────────────────────── */
    main {
      height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-top: 71px;
    }

    /* ── LEFT ───────────────────────────────── */
    .left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 52px;
      border-right: 1px solid var(--line);
    }

    .eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .eyebrow::before {
      content: '';
      display: block;
      width: 36px; height: 1px;
      background: rgba(255,255,255,0.28);
    }

    h1 {
      font-size: clamp(34px, 3.6vw, 54px);
      font-weight: 200;
      line-height: 1.13;
      letter-spacing: -0.025em;
      margin-bottom: 22px;
    }

    h1 em { font-style: italic; font-weight: 300; color: var(--white); }

    .sub {
      font-size: 14px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.75;
      max-width: 400px;
      margin-bottom: 36px;
    }

    .flow {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 36px;
    }

    .flow-tag {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.42);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 6px 12px;
      border-radius: 2px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .flow-tag::after {
      content: '→';
      color: rgba(255,255,255,0.45);
      font-size: 10px;
    }

    .flow-tag:last-child::after { display: none; }

    /* ── GITHUB BUTTON ──────────────────────── */
    .github-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--white);
      color: var(--black);
      text-decoration: none;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 14px 24px;
      border-radius: 3px;
      transition: opacity 0.2s;
      width: fit-content;
    }

    .github-btn:hover { opacity: 0.87; }
    .github-btn svg { flex-shrink: 0; }

    .hint {
      margin-top: 12px;
      font-size: 11px;
      color: var(--dimmer);
      font-family: 'DM Mono', monospace;
      letter-spacing: 0.06em;
    }

    /* ── RIGHT ──────────────────────────────── */
    .right {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .right::before {
      content: '';
      position: absolute;
      width: 500px; height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 65%);
      pointer-events: none;
    }

    /* ── 3D SCENE ───────────────────────────── */
    .scene {
      position: relative;
      width: 360px; height: 360px;
      perspective: 1100px;
      margin-bottom: 32px;
    }

    .ring {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.1);
      transform-style: preserve-3d;
      animation: spinRing 20s linear infinite;
    }

    .ring::after {
      content: '';
      position: absolute;
      top: 50%; left: -5px;
      width: 10px; height: 10px;
      background: var(--white);
      border-radius: 50%;
      transform: translateY(-50%);
      box-shadow: 0 0 16px 4px rgba(255,255,255,0.28);
    }

    .ring-2 {
      inset: 50px;
      border-color: rgba(255,255,255,0.06);
      animation: spinRing 13s linear infinite reverse;
    }

    .ring-2::after {
      background: rgba(255,255,255,0.7);
      width: 7px; height: 7px;
      left: -3.5px;
      box-shadow: 0 0 12px 3px rgba(255,255,255,0.18);
    }

    .ring-3 {
      inset: 100px;
      border-color: rgba(255,255,255,0.04);
      animation: spinRing 8s linear infinite;
    }

    .ring-3::after {
      width: 5px; height: 5px;
      left: -2.5px;
      background: rgba(255,255,255,0.5);
      box-shadow: 0 0 8px 2px rgba(255,255,255,0.15);
    }

    @keyframes spinRing {
      from { transform: rotateX(70deg) rotateZ(0deg); }
      to   { transform: rotateX(70deg) rotateZ(360deg); }
    }

    .cube-wrap {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cube {
      width: 90px; height: 90px;
      position: relative;
      transform-style: preserve-3d;
      animation: spinCube 11s ease-in-out infinite;
    }

    @keyframes spinCube {
      0%   { transform: rotateX(12deg) rotateY(0deg); }
      25%  { transform: rotateX(12deg) rotateY(90deg); }
      50%  { transform: rotateX(12deg) rotateY(180deg); }
      75%  { transform: rotateX(12deg) rotateY(270deg); }
      100% { transform: rotateX(12deg) rotateY(360deg); }
    }

    .face {
      position: absolute;
      width: 90px; height: 90px;
      border: 1px solid rgba(255,255,255,0.14);
      background: rgba(255,255,255,0.03);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.18em;
      color: rgba(255,255,255,0.38);
    }

    .face-front  { transform: translateZ(45px); }
    .face-back   { transform: rotateY(180deg) translateZ(45px); }
    .face-left   { transform: rotateY(-90deg) translateZ(45px); }
    .face-right  { transform: rotateY(90deg) translateZ(45px); }
    .face-top    { transform: rotateX(90deg) translateZ(45px); }
    .face-bottom { transform: rotateX(-90deg) translateZ(45px); }

    /* ── FLOATING CARDS ─────────────────────── */
    .verdict-card {
      position: absolute;
      top: 24px; right: -10px;
      background: rgba(0,0,0,0.92);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 8px;
      padding: 12px 16px;
      font-family: 'DM Mono', monospace;
      backdrop-filter: blur(12px);
      animation: floatCard 4s ease-in-out infinite;
    }

    @keyframes floatCard {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .verdict-label {
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 4px;
    }

    .verdict-value {
      font-size: 13px;
      font-weight: 500;
      color: var(--white);
    }

    .waste-card {
      position: absolute;
      bottom: 32px; left: -10px;
      background: rgba(0,0,0,0.92);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      padding: 12px 16px;
      font-family: 'DM Mono', monospace;
      backdrop-filter: blur(12px);
      animation: floatCard 4s ease-in-out 2s infinite;
    }

    .waste-label {
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 4px;
    }

    .waste-value {
      font-size: 13px;
      font-weight: 500;
      color: rgba(255,255,255,0.72);
    }

    /* ── STATS ROW ───────────────────────────── */
    .stats {
      display: flex;
      border-top: 1px solid var(--line);
      width: 100%;
    }

    .stat {
      flex: 1;
      padding: 18px 20px;
      text-align: center;
      border-right: 1px solid var(--line);
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .stat:last-child { border-right: none; }

    .stat-num {
      font-family: 'DM Mono', monospace;
      font-size: 22px;
      font-weight: 400;
      color: var(--white);
      display: block;
      margin-bottom: 4px;
    }

    .stat-label {
      font-size: 9px;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
    }

    /* ── FOOTER ─────────────────────────────── */
    footer {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      padding: 14px 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid var(--line);
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(12px);
    }

    footer span {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--dimmer);
      letter-spacing: 0.08em;
    }

    /* ── ASK WIDGET ─────────────────────────── */
    .ask-btn {
      position: fixed;
      bottom: 56px; right: 30px;
      width: 46px; height: 46px;
      background: var(--white);
      color: var(--black);
      border: none;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 200;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .ask-btn:hover {
      transform: scale(1.08);
      box-shadow: 0 0 0 8px rgba(255,255,255,0.06);
    }

    .ask-btn svg { width: 18px; height: 18px; }

    .ask-panel {
      position: fixed;
      bottom: 114px; right: 30px;
      width: 296px;
      background: #0a0a0a;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      overflow: hidden;
      z-index: 200;
      transform: scale(0.9) translateY(14px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1), opacity 0.18s ease;
      transform-origin: bottom right;
    }

    .ask-panel.open {
      transform: scale(1) translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    .ask-header {
      padding: 14px 18px;
      border-bottom: 1px solid var(--line);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .ask-dot {
      width: 7px; height: 7px;
      background: var(--white);
      border-radius: 50%;
      animation: dotpulse 2s ease-in-out infinite;
    }

    @keyframes dotpulse {
      0%,100% { opacity:1; transform:scale(1); }
      50% { opacity:0.3; transform:scale(0.6); }
    }

    .ask-title {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.1em;
      color: var(--white);
    }

    .ask-body { padding: 14px 18px; }

    .ask-body p {
      font-size: 12px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.6;
      margin-bottom: 12px;
    }

    .ask-form {
      display: flex;
      border: 1px solid var(--line);
      border-radius: 4px;
      overflow: hidden;
    }

    .ask-form input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--white);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      padding: 10px 12px;
    }

    .ask-form input::placeholder { color: rgba(255,255,255,0.2); }

    .ask-form button {
      background: var(--white);
      color: var(--black);
      border: none;
      cursor: pointer;
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.1em;
      padding: 10px 14px;
      transition: opacity 0.2s;
    }

    .ask-form button:hover { opacity: 0.8; }
  </style>
</head>
<body>

  <a href="/" style="position:fixed; top:20px; left:24px; z-index:1000;">
    <img src="/grassion-logo-white.svg" alt="Grassion" style="height:36px;" />
  </a>

  <header>
    <nav>
      <a href="/about/">About</a>
      <a href="mailto:info@grassion.com">Contact</a>
    </nav>
  </header>

  <main>
    <!-- LEFT: COPY -->
    <div class="left">
      <div class="eyebrow">AI Coding ROI Intelligence</div>

      <h1>Where AI Code<br>Meets<br><em>Accountability.</em></h1>

      <p class="sub">
        The first system that tells engineering teams whether AI is creating value — or silently creating rework.
      </p>

      <div class="flow">
        <span class="flow-tag">Connect</span>
        <span class="flow-tag">Detect</span>
        <span class="flow-tag">Measure</span>
        <span class="flow-tag">Decide</span>
      </div>

      <a class="github-btn" href="https://grassion-api.fly.dev/auth/github">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        Sign in with GitHub
      </a>
      <p class="hint">14-day free trial &nbsp;·&nbsp; 5-minute GitHub setup</p>
    </div>

    <!-- RIGHT: 3D + STATS -->
    <div class="right">
      <div class="verdict-card" style="z-index:10;">
        <div class="verdict-label">This month</div>
        <div class="verdict-value">NET POSITIVE +$1,220</div>
      </div>

      <div class="scene">
        <div class="ring"></div>
        <div class="ring ring-2"></div>
        <div class="ring ring-3"></div>
        <div class="cube-wrap">
          <div class="cube">
            <div class="face face-front">ROI</div>
            <div class="face face-back">DATA</div>
            <div class="face face-left">TRACK</div>
            <div class="face face-right">SIGNAL</div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
          </div>
        </div>
      </div>

      <div class="waste-card" style="z-index:10;">
        <div class="waste-label">Unused seats found</div>
        <div class="waste-value">8 seats · $152/mo wasted</div>
      </div>

      <div class="stats">
        <div class="stat" id="s1">
          <span class="stat-num">85%</span>
          <span class="stat-label">Devs use AI tools</span>
        </div>
        <div class="stat" id="s2">
          <span class="stat-num">0%</span>
          <span class="stat-label">Have ROI visibility</span>
        </div>
        <div class="stat" id="s3">
          <span class="stat-num">5 min</span>
          <span class="stat-label">To first insight</span>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <span>© 2026 Grassion Intelligence</span>
    <span>Where AI Code Meets Accountability</span>
  </footer>

  <!-- ASK WIDGET -->
  <button class="ask-btn" id="askToggle" title="Ask us anything">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="ask-panel" id="askPanel">
    <div class="ask-header">
      <div class="ask-dot"></div>
      <span class="ask-title">Ask us anything</span>
    </div>
    <div class="ask-body">
      <p>Question about Grassion or want early access? We reply personally.</p>
      <div class="ask-form">
        <input type="text" id="askInput" placeholder="Type your question..." />
        <button id="askSend">Send</button>
      </div>
    </div>
  </div>

  <script is:inline>
    const panel = document.getElementById('askPanel');
    const toggle = document.getElementById('askToggle');
    toggle.addEventListener('click', () => panel.classList.toggle('open'));
    document.addEventListener('click', e => {
      if (!panel.contains(e.target) && !toggle.contains(e.target))
        panel.classList.remove('open');
    });

    document.getElementById('askSend').addEventListener('click', () => {
      const q = document.getElementById('askInput').value.trim();
      if (!q) return;
      window.location.href = `mailto:info@grassion.com?subject=Question via grassion.com&body=${encodeURIComponent(q)}`;
    });

    document.getElementById('askInput').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('askSend').click();
    });

    window.addEventListener('load', () => {
      ['s1','s2','s3'].forEach((id, i) => {
        setTimeout(() => {
          const el = document.getElementById(id);
          if (el) { el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }
        }, 500 + i * 150);
      });
    });
  </script>

</body>
</html>
