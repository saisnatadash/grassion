---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About · Grassion</title>
  <meta name="description" content="Grassion's mission: make AI coding ROI visible and actionable for every engineering team." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,200;0,9..40,300;0,9..40,400;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #000000;
      --white: #ffffff;
      --dim: rgba(255,255,255,0.38);
      --dimmer: rgba(255,255,255,0.18);
      --line: rgba(255,255,255,0.09);
    }

    html, body {
      background: var(--black);
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
    }

    /* ── HEADER ─────────────────────────────── */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 18px 52px;
      z-index: 100;
      border-bottom: 1px solid var(--line);
      background: rgba(0,0,0,0.85);
      backdrop-filter: blur(16px);
    }

    nav { display: flex; gap: 40px; align-items: center; }
    nav a {
      font-size: 11px;
      font-weight: 300;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
      text-decoration: none;
      transition: color 0.2s;
    }
    nav a:hover, nav a.active { color: var(--white); }

    .logo-link {
      position: fixed;
      top: 20px; left: 24px;
      z-index: 1000;
    }
    .logo-link img { height: 36px; display: block; }

    /* ── MAIN ───────────────────────────────── */
    main {
      padding: 120px 52px 80px;
      max-width: 1100px;
      margin: 0 auto;
    }

    /* ── EYEBROW ────────────────────────────── */
    .eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 36px; height: 1px;
      background: rgba(255,255,255,0.28);
    }

    /* ── HERO ───────────────────────────────── */
    .hero { margin-bottom: 80px; border-bottom: 1px solid var(--line); padding-bottom: 64px; }

    h1 {
      font-size: clamp(36px, 4vw, 58px);
      font-weight: 200;
      line-height: 1.1;
      letter-spacing: -0.025em;
      margin-bottom: 24px;
    }
    h1 em { font-style: italic; font-weight: 300; }

    .hero-body {
      max-width: 560px;
      font-size: 15px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.75;
    }
    .hero-body p + p { margin-top: 16px; }

    /* ── SECTION HEADER ─────────────────────── */
    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 32px;
    }

    /* ── UPCOMING FEATURES ──────────────────── */
    .features-section { margin-bottom: 80px; border-bottom: 1px solid var(--line); padding-bottom: 64px; }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
    }

    .feature-card {
      background: var(--black);
      padding: 32px 28px;
    }

    .feature-num {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: rgba(255,255,255,0.2);
      letter-spacing: 0.1em;
      margin-bottom: 20px;
    }

    .feature-title {
      font-size: 16px;
      font-weight: 300;
      margin-bottom: 12px;
      line-height: 1.3;
    }

    .feature-desc {
      font-size: 13px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.65;
    }

    .coming-soon {
      display: inline-block;
      margin-top: 16px;
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 4px 10px;
    }

    /* ── TEAM ───────────────────────────────── */
    .team-section { margin-bottom: 60px; }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--line);
      border: 1px solid var(--line);
    }

    .team-card {
      background: var(--black);
      padding: 36px 28px;
      display: flex;
      flex-direction: column;
    }

    .team-card.apply {
      align-items: center;
      justify-content: center;
      text-align: center;
      cursor: pointer;
      transition: background 0.2s;
    }
    .team-card.apply:hover { background: rgba(255,255,255,0.02); }

    .founder-photo {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      object-fit: cover;
      border: 1px solid var(--line);
      margin-bottom: 20px;
      background: rgba(255,255,255,0.05);
    }

    .founder-photo-placeholder {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      border: 1px solid var(--line);
      margin-bottom: 20px;
      background: rgba(255,255,255,0.05);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: rgba(255,255,255,0.2);
      letter-spacing: 0.1em;
    }

    .founder-name {
      font-size: 16px;
      font-weight: 300;
      margin-bottom: 4px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .founder-role {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 16px;
    }

    .founder-bio {
      font-size: 13px;
      font-weight: 300;
      color: var(--dim);
      line-height: 1.65;
      flex: 1;
    }

    .linkedin-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px; height: 28px;
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 4px;
      color: var(--dim);
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s;
      flex-shrink: 0;
    }
    .linkedin-icon:hover { border-color: rgba(255,255,255,0.4); color: var(--white); }
    .linkedin-icon svg { width: 14px; height: 14px; }

    .apply-q {
      font-size: 48px;
      font-weight: 200;
      color: rgba(255,255,255,0.15);
      margin-bottom: 16px;
      line-height: 1;
    }

    .apply-label {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 20px;
    }

    .apply-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid rgba(255,255,255,0.2);
      color: var(--white);
      text-decoration: none;
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 10px 18px;
      transition: background 0.2s, border-color 0.2s;
    }
    .apply-btn:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.4); }

    /* ── FOOTER ─────────────────────────────── */
    footer {
      border-top: 1px solid var(--line);
      padding: 20px 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    footer span {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--dimmer);
      letter-spacing: 0.08em;
    }

    footer a {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--dimmer);
      letter-spacing: 0.08em;
      text-decoration: none;
      transition: color 0.2s;
    }
    footer a:hover { color: var(--white); }

    /* ── FLOATING ELEMENT ───────────────────── */
    .float-badge {
      position: fixed;
      bottom: 80px;
      right: 28px;
      background: rgba(10,10,10,0.95);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      padding: 12px 16px;
      font-family: 'DM Mono', monospace;
      backdrop-filter: blur(12px);
      z-index: 50;
      animation: floatBadge 4s ease-in-out infinite;
    }
    @keyframes floatBadge {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    .float-badge-label {
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
      margin-bottom: 4px;
    }
    .float-badge-value {
      font-size: 12px;
      font-weight: 500;
      color: var(--white);
    }

    /* ── MOBILE ─────────────────────────────── */
    @media (max-width: 767px) {
      .logo-link { top: 14px; left: 16px; }
      .logo-link img { height: 28px; }
      header { padding: 14px 16px; }
      nav { gap: 18px; }

      main { padding: 88px 24px 60px; }

      h1 { font-size: clamp(28px, 9vw, 40px); }

      .features-grid { grid-template-columns: 1fr; }
      .team-grid { grid-template-columns: 1fr; }

      footer { padding: 16px 24px; flex-direction: column; gap: 8px; text-align: center; }

      .float-badge { display: none; }
    }
  </style>
</head>
<body>

  <a href="/" class="logo-link">
    <img src="/grassion-logo-white.svg" alt="Grassion" onerror="this.style.display='none'" />
  </a>

  <header>
    <nav>
      <a href="/" >Home</a>
      <a href="/about/" class="active">About</a>
      <a href="/pricing/">Pricing</a>
      <a href="/contact/">Contact</a>
    </nav>
  </header>

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="eyebrow">Who We Are</div>
      <h1>Built to answer one<br>question: <em>is AI paying off?</em></h1>
      <div class="hero-body">
        <p>
          Every engineering team in 2026 is spending real money on AI coding tools.
          Most have no way to know if it's working. Grassion changes that.
        </p>
        <p>
          We read GitHub metadata — commits, PRs, reverts, CI signals — and turn it into
          a single, honest verdict: Net Positive, Neutral, or Negative. No code ever leaves
          your servers. No agents. No prompts on your codebase.
        </p>
      </div>
    </section>

    <!-- UPCOMING FEATURES -->
    <section class="features-section">
      <div class="section-label">What's Coming</div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-num">01</div>
          <div class="feature-title">Slack & Email Alerts</div>
          <p class="feature-desc">
            Get notified the moment ROI dips below your threshold. Real-time signals,
            not week-old reports.
          </p>
          <span class="coming-soon">Q3 2026</span>
        </div>
        <div class="feature-card">
          <div class="feature-num">02</div>
          <div class="feature-title">Team Benchmarking</div>
          <p class="feature-desc">
            Compare ROI across squads, repos, and AI tools side-by-side. Know where
            AI is winning and where it's creating drag.
          </p>
          <span class="coming-soon">Q3 2026</span>
        </div>
        <div class="feature-card">
          <div class="feature-num">03</div>
          <div class="feature-title">Custom Detection Rules</div>
          <p class="feature-desc">
            Define your own AI label patterns and commit trailer formats. Grassion adapts
            to your team's conventions, not the other way around.
          </p>
          <span class="coming-soon">Q4 2026</span>
        </div>
      </div>
    </section>

    <!-- TEAM -->
    <section class="team-section">
      <div class="section-label">The Team</div>
      <div class="team-grid">

        <!-- Sai -->
        <div class="team-card">
          <img
            class="founder-photo"
            src="/founder-sai.jpg"
            alt="Sai Snata Dash"
            onerror="this.style.display='none'"
          />
          <div class="founder-name">
            Sai Snata Dash
            <a
              class="linkedin-icon"
              href="https://www.linkedin.com/in/saisnatadash"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Sai on LinkedIn"
            >
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
          <div class="founder-role">Founder &amp; CEO</div>
          <p class="founder-bio">
            Product leader, orator, and LinkedIn influencer with 13k+ connections.
            Thiel Fellow and Karmaveer Chakra Awardee recognized by the United Nations.
            40+ certifications from Google, Harvard, and Startup India. Built an ephemeral
            social platform scaled to 50k+ users worldwide. Awarded by the Chief Minister
            of Odisha for healthcare innovation.
          </p>
        </div>

        <!-- Mukti -->
        <div class="team-card">
          <img
            class="founder-photo"
            src="/founder-mukti.jpg"
            alt="Mukti Prasad Behera"
            onerror="this.style.display='none'"
          />
          <div class="founder-name">
            Mukti Prasad Behera
            <a
              class="linkedin-icon"
              href="https://www.linkedin.com/in/mukti-prasad-behera/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Mukti on LinkedIn"
            >
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
          <div class="founder-role">Co-Founder &amp; CTO</div>
          <p class="founder-bio">
            Full-stack engineer with 6+ years building complex systems and microservices
            at infrastructure scale. Core expertise in JavaScript. Has served as CTO and
            technical lead across multiple high-scale engineering teams.
          </p>
        </div>

        <!-- Apply -->
        <div class="team-card apply">
          <div class="apply-q">?</div>
          <div class="apply-label">Open Position</div>
          <p class="founder-bio" style="margin-bottom: 24px; font-size: 13px;">
            We're building the future of AI accountability.<br>
            Think you belong here?
          </p>
          <a class="apply-btn" href="/contact/">
            Apply Now
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>
    </section>

  </main>

  <footer>
    <span>© 2026 Grassion Intelligence</span>
    <div style="display:flex; gap:24px;">
      <a href="/privacy/">Privacy</a>
      <a href="/terms/">Terms</a>
      <a href="mailto:info@grassion.com">info@grassion.com</a>
    </div>
  </footer>

  <!-- Floating element -->
  <div class="float-badge">
    <div class="float-badge-label">Now in Beta</div>
    <div class="float-badge-value">14-day free trial</div>
  </div>

</body>
</html>
