# Database
DATABASE_URL=postgres://user:pass@host:5432/grassion

# GitHub App (create at https://github.com/settings/apps/new)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=grassion

# Auth
JWT_SECRET=replace_with_random_64_char_string
SESSION_COOKIE_DOMAIN=.grassion.com

# Razorpay (primary billing for v1; KYC takes 1-2 days, start early)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_STARTER=plan_...

# OpenAI (used ONLY for human-readable PR risk summaries)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MONTHLY_BUDGET_USD=10

# Resend (transactional email — weekly digests)
RESEND_API_KEY=re_...
EMAIL_FROM="Grassion <hello@grassion.com>"

# Zoho SMTP (contact-form auto-reply only; not transactional)
ZOHO_SMTP_HOST=smtp.zoho.in
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=contact@grassion.com
ZOHO_SMTP_PASS=
ZOHO_FROM_ADDRESS=contact@grassion.com
ZOHO_TO_ADDRESS=contact@grassion.com

# URLs
APP_URL=https://app.grassion.com
API_URL=https://api.grassion.com
MARKETING_URL=https://grassion.com

# Node
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
